{
    "name": "sharenjoy/noah-domain",
    "version": "dev-main",
    "description": "Shared domain models for Noah ecosystem",
    "keywords": [
        "Sharenjoy",
        "laravel",
        "noah-domain"
    ],
    "homepage": "https://github.com/sharenjoy/noah-domain",
    "license": "MIT",
    "authors": [
        {
            "name": "Ronald",
            "email": "ronald.jian@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "appstract/laravel-stock": "^1.2",
        "illuminate/contracts": "^11.0||^12.0||^13.0",
        "lorisleiva/laravel-actions": "^2.10",
        "mcamara/laravel-localization": "^2.2",
        "outerweb/filament-settings": "^2.3.1",
        "ralphjsmit/laravel-seo": "^1.6",
        "overtrue/laravel-pinyin": "^6.0",
        "solution-forest/filament-tree": "^4.0",
        "spatie/eloquent-sortable": "^5.0.1",
        "spatie/laravel-medialibrary": "^11.21",
        "spatie/laravel-translatable": "^6.13",
        "spatie/laravel-permission": "^7.2"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0||^9.0"
    },
    "autoload": {
        "psr-4": {
            "Sharenjoy\\NoahDomain\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sharenjoy\\NoahDomain\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
